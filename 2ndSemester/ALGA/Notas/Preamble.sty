\titleformat{\section}
{\Large\bfseries}
{\thesection.}{0.5em}{}[
  \vspace{0.5cm}
  \hrule
  \vspace{0.5cm}
]

\titleformat{\subsection}
{\large\bfseries}
{\thesubsection.}{0.5em}{}[
  \hrule width 3.35in
  \vspace{0.5cm}
]

